# PostgreSQL (обязательно)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Порты (опционально, для docker-compose)
DB_PORT=5432
BACKEND_PORT=8000

# Django (обязательно)
SECRET_KEY=
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Бот -> Django: хук уведомлений (опционально)
BOT_INTERNAL_URL=

# Telegram Bot (обязательно для бота)
BOT_TOKEN=
# Для локального запуска подставьте свои POSTGRES_*. В Docker подставляется из compose.
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Порт HTTP-хука /notify в боте (опционально)
BOT_NOTIFY_PORT=8080

# Медиа для бота: базовый URL бэкенда (без /media в конце)
MEDIA_BASE_URL=http://localhost:8000

# WebApp: URL Mini App (https://…). Бот: кнопка меню и «Открыть магазин». Django: CORS и initData.
TELEGRAM_WEBAPP_HOST=

# WebApp: URL API с точки зрения браузера (опционально, в Docker по умолчанию localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# При DEBUG=1: telegram_id для запросов WebApp без initData (тест в браузере на localhost:3000)
# DEV_WEBAPP_TELEGRAM_ID=123456789
