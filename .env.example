# =============================================================================
# Скопируйте в .env и заполните значения. Пустые строки недопустимы там,
# где в комментарии сказано «обязательно».
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Обязательно. В docker compose хост/порт для backend подставляются в сервисе;
# для Django на машине без Docker оставьте POSTGRES_HOST=localhost.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
SECRET_KEY=
DEBUG=true
# Через запятую, без пробелов. Добавьте домен или IP, с которого открывают сайт.
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# -----------------------------------------------------------------------------
# Telegram и публичные URL
# -----------------------------------------------------------------------------
BOT_TOKEN=
# В Docker prod: http://bot:8080 (порт = BOT_NOTIFY_PORT ниже).
BOT_INTERNAL_URL=
BOT_NOTIFY_PORT=8080

# Публичный URL магазина (nginx): https://домен или https://IP — без слэша в конце.
# CORS/CSRF в Django берутся отсюда.
TELEGRAM_WEBAPP_HOST=

# База для ссылок на медиа в боте (без /media в конце). В prod совпадает с хостом сайта.
MEDIA_BASE_URL=http://localhost:8000

# Username бота без @. Короткое имя Direct Link в @BotFather → t.me/bot/SHORT (например minishop).
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINIAPP_SHORT_NAME=

# Бот: скачивание файлов рассылки. В compose для prod/dev задано http://backend:8000; вне Docker — пусто.
# MEDIA_FETCH_BASE_URL=

# Только при DEBUG=true: WebApp в браузере без initData.
# DEV_WEBAPP_TELEGRAM_ID=

# -----------------------------------------------------------------------------
# Next.js (webapp)
# -----------------------------------------------------------------------------
# Пусто за nginx = API с того же origin. Для dev без nginx: http://localhost:8000
# NEXT_PUBLIC_API_URL=

# SSR/превью товара: из контейнера webapp к backend. В compose по умолчанию не нужно менять.
BACKEND_INTERNAL_URL=http://backend:8000

# Prod (docker compose build + runtime): один и тот же ключ, не менять между пересборками.
# Сгенерировать: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Docker Compose — dev (docker-compose.yml)
# -----------------------------------------------------------------------------
DB_PORT=5432
BACKEND_PORT=8000
NGINX_PORT=80

# -----------------------------------------------------------------------------
# Docker Compose — prod (docker-compose.prod.yml): nginx + TLS
# -----------------------------------------------------------------------------
NGINX_HTTPS_PORT=443
# server_name в nginx: домен(ы) через пробел, без https:// и без порта.
# Let's Encrypt: только FQDN (например shop.duckdns.org), не «голый» IP — иначе certbot откажет.
# Бесплатный домен: DuckDNS / поддомен у регистратора → A-запись на IP сервера.
NGINX_SERVER_NAME=
# Папка сертификата: ssl/live/<имя>/; пусто = первое слово из NGINX_SERVER_NAME.
# SSL_LETSENCRYPT_HOST=
CERTBOT_EMAIL=

# -----------------------------------------------------------------------------
# Бот вне Docker (локально)
# -----------------------------------------------------------------------------
# В compose для сервиса bot строка подставляется из POSTGRES_* автоматически.
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DBNAME
