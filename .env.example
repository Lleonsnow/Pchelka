# PostgreSQL
POSTGRES_DB=tgshop
POSTGRES_USER=tgshop
POSTGRES_PASSWORD=change_me_strong_password

# Django
SECRET_KEY=change_me_django_secret_key_min_50_chars
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
# URL медиа (фото товаров). Без слэша в конце. Если пусто — фото не отправляются.
MEDIA_BASE_URL=http://localhost:8000/media

# WebApp (URL для валидации initData и CORS)
TELEGRAM_WEBAPP_HOST=https://your-webapp-domain.com

# Внутренний URL бота для хуков уведомлений (Django -> Bot)
# Локально можно не задавать, уведомления через хук отключены
BOT_INTERNAL_URL=http://bot:8080
