# PostgreSQL (обязательно)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Порты (опционально, для docker-compose)
DB_PORT=5432
BACKEND_PORT=8000
NGINX_PORT=80

# Django (обязательно)
SECRET_KEY=
DEBUG=true
# Для Telegram: добавьте хост ngrok в ALLOWED_HOSTS (один туннель на nginx:80)
# Пример: ALLOWED_HOSTS=localhost,127.0.0.1,backend,22c9-45-85-105-208.ngrok-free.app
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Django -> бот: хук уведомлений (опционально)
# В Docker: BOT_INTERNAL_URL=http://bot:8080 (тот же порт, что BOT_NOTIFY_PORT)
BOT_INTERNAL_URL=

# Telegram Bot (обязательно для бота)
BOT_TOKEN=
# Для локального запуска подставьте свои POSTGRES_*. В Docker подставляется из compose.
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Порт HTTP-хука /notify в боте (опционально)
BOT_NOTIFY_PORT=8080

# Медиа для бота: базовый URL бэкенда (без /media в конце)
MEDIA_BASE_URL=http://localhost:8000

# WebApp: единственный публичный URL (nginx). Бот: кнопка меню. Django: CORS и CSRF.
# Один туннель: ngrok http 80 → сюда подставьте https://xxxx.ngrok-free.app
TELEGRAM_WEBAPP_HOST=

# Пусто = запросы к API идут на тот же домен (через nginx). Только для разработки без nginx: NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=

# При DEBUG=1: telegram_id для запросов WebApp без initData (тест в браузере на localhost:3000)
# DEV_WEBAPP_TELEGRAM_ID=123456789
