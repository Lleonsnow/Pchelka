# PostgreSQL (обязательно)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Порты (опционально, для docker-compose)
DB_PORT=5432
BACKEND_PORT=8000
NGINX_PORT=80
# HTTPS (docker-compose.prod.yml)
NGINX_HTTPS_PORT=443

# --- Prod: TLS (Let's Encrypt), см. nginx/nginx.prod.conf.template и scripts/certbot-*.sh ---
# Домен с A-записью на сервер (не IP). Несколько имён через пробел, если все в одном сертификате.
NGINX_SERVER_NAME=
# Каталог на диске: ssl/live/<SSL_LETSENCRYPT_HOST>/ (первый -d у certbot). Пусто = первое слово из NGINX_SERVER_NAME
# SSL_LETSENCRYPT_HOST=
# Email для соглашения Let's Encrypt
CERTBOT_EMAIL=

# Django (обязательно)
SECRET_KEY=
DEBUG=true
# Для Telegram: добавьте хост ngrok в ALLOWED_HOSTS (один туннель на nginx:80)
# Пример: ALLOWED_HOSTS=localhost,127.0.0.1,backend,22c9-45-85-105-208.ngrok-free.app
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Django -> бот: хук уведомлений (опционально)
# В Docker: BOT_INTERNAL_URL=http://bot:8080 (тот же порт, что BOT_NOTIFY_PORT)
BOT_INTERNAL_URL=

# Telegram Bot (обязательно для бота)
BOT_TOKEN=
# Username бота без @ (@mybot → mybot)
TELEGRAM_BOT_USERNAME=
# Короткое имя Mini App: @BotFather → ваш бот → Mini Apps → имя в ссылке t.me/bot/ИМЯ (часто не совпадает с username; без него шаринг даст t.me/bot?start=product_<id>)
TELEGRAM_MINIAPP_SHORT_NAME=
# Для локального запуска подставьте свои POSTGRES_*. В Docker подставляется из compose.
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Порт HTTP-хука /notify в боте (опционально)
BOT_NOTIFY_PORT=8080

# Медиа для бота: базовый URL бэкенда (без /media в конце)
MEDIA_BASE_URL=http://localhost:8000

# WebApp: единственный публичный URL (nginx). Бот: кнопка меню. Django: CORS и CSRF.
# Prod с TLS: https://ваш-домен (без слэша в конце)
TELEGRAM_WEBAPP_HOST=

# Пусто = запросы к API идут на тот же домен (через nginx). Только для разработки без nginx: NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=

# URL бэкенда для SSR Next (превью ссылки на товар): из контейнера webapp. В compose по умолчанию http://backend:8000; локально next dev — http://127.0.0.1:8000
BACKEND_INTERNAL_URL=http://backend:8000

# При DEBUG=1: telegram_id для запросов WebApp без initData (тест в браузере на localhost:3000)
# DEV_WEBAPP_TELEGRAM_ID=123456789
